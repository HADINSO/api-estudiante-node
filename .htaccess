# ══════════════════════════════════════════════════════
#  .htaccess — Redirige todas las peticiones a index.php
#  Necesario para que las URLs limpias funcionen en Apache
# ══════════════════════════════════════════════════════

Options -Indexes

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
